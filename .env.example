# Google Gemini API key (https://aistudio.google.com/apikey). Required for audits + AI analysis.
GEMINI_API_KEY=your-gemini-api-key

# Gemini model id used by both the agentic auditor and the report analyzer.
# Defaults to gemini-2.5-flash if unset. Other options: gemini-3.5-flash, gemini-3.1-pro-preview.
GEMINI_MODEL=gemini-2.5-flash

# Max Gemini requests per minute. The free tier allows ~3 RPM; keep this at 2
# to stay safely under the limit. All Gemini calls share this throttle.
GEMINI_RPM=2
